    "/invocations/stream": {
      "get": {
        "summary": "Chat Stream",
        "description": "Streaming chat endpoint using Server-Sent Events.",
        "operationId": "chat_stream_invocations_stream_get",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
